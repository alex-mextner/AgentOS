---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import EngineeringIndex from '../components/EngineeringIndex.tsx';
import { listDocs } from '../lib/bible';
import { loadIssues } from '../lib/github';

const docs = listDocs();
const { ok: issuesOk, issues } = await loadIssues(10);

const catLabels: Record<string, string> = {
  architecture: 'Architecture',
  product: 'Product',
  research: 'Research',
  hardware: 'Hardware',
  legal: 'Legal',
  planning: 'Planning',
  decisions: 'Decisions',
  governance: 'Governance',
  glossary: 'Glossary',
  validation: 'Validation',
  vision: 'Vision',
  general: 'General',
};
---

<BaseLayout
  title="Engineering bible"
  description="Agent OS specifications across product vision, architecture, security, hardware, research, legal, governance and execution planning."
>
  <PageHeader
    eyebrow="Engineering bible"
    title="The Agent OS engineering corpus."
    lede={`${docs.length} versioned specifications with stable identifiers, explicit status and evidence requirements across product vision, architecture, hardware, security, research, legal controls and execution planning.`}
  />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 max-w-2xl">
        <div class="eyebrow mb-3">Specifications</div>
        <h2 class="text-balance text-3xl font-semibold tracking-tight md:text-4xl">Explore by discipline.</h2>
        <p class="mt-4 text-pretty text-base leading-relaxed text-muted-foreground md:text-lg">
          Product vision, architecture, hardware, research, legal controls, governance, decisions and execution plans form one cross-linked body of work.
        </p>
      </div>
      <EngineeringIndex client:load docs={docs} labels={catLabels} />
    </div>
  </section>

  {
    issuesOk && issues.length > 0 && (
      <section class="section">
        <div class="mx-auto max-w-6xl px-6">
          <SectionHeader
            eyebrow="Execution"
            title="Current engineering work."
            lede="Active work items connect implementation, experiments, decisions and acceptance evidence to the specifications they advance."
          />
          <div class="mt-10 overflow-hidden rounded-xl border border-border">
            {issues.map((issue, i) => (
              <a
                href={issue.url}
                rel="noopener"
                class={
                  'group flex items-center gap-4 px-4 py-3.5 transition-colors hover:bg-accent/30 sm:px-5 ' +
                  (i > 0 ? 'border-t border-border' : '')
                }
              >
                <span class="w-12 shrink-0 font-mono text-xs text-muted-foreground">#{issue.number}</span>
                <span class="flex-1 truncate text-sm text-foreground">{issue.title}</span>
                <span class={
                  'shrink-0 rounded-md border px-2 py-0.5 font-mono text-[0.68rem] ' +
                  (issue.state === 'open'
                    ? 'border-emerald-500/40 bg-emerald-500/10 text-emerald-400'
                    : 'border-border bg-muted/40 text-muted-foreground')
                }>{issue.state}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>
