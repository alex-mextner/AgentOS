---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PillarGrid from '../components/PillarGrid.astro';
import LayerStack from '../components/LayerStack.astro';
import AppLastDiagram from '../components/AppLastDiagram.astro';
import FeatureTiles from '../components/FeatureTiles.astro';
import GlobalAccount from '../components/GlobalAccount.astro';
import MicroApps from '../components/MicroApps.astro';
import AgentMeshTeaser from '../components/AgentMeshTeaser.astro';
import SpecLinks from '../components/SpecLinks.astro';
import CtaBand from '../components/CtaBand.astro';

const rules = [
  {
    title: 'One object, many surfaces',
    body: 'A person is not five contacts. A project is not a folder plus a chat plus a board plus a calendar — it is one entity, rendered as a card, table, timeline, map, micro-app or agent context.',
    cite: 'AOS-ARCH-009',
  },
  {
    title: 'One action model, many callers',
    body: 'The same typed action can be invoked from a button, micro-app, command palette, script or agent under explicit authority — with no private backdoor to state.',
    cite: 'AOS-ARCH-010',
  },
  {
    title: 'Replaceable providers and transports',
    body: 'Storage, data, actions, rendering, radio and hardware backends can change while entity and action semantics stay stable. Foreign types stop at adapters.',
    cite: 'AOS-ARCH-024',
  },
  {
    title: 'Evidence before promises',
    body: 'Claims, experiments, risks and acceptance gates constrain implementation and every public support statement. No assumption becomes a requirement just because it appeared in a spec.',
    cite: 'AOS-BRIEF',
  },
];
---

<BaseLayout
  title="How it works"
  description="How Agent OS works: app-last entities, typed actions, generated micro-apps, Agent Mesh peer connectivity, explicit capabilities and portable system contracts."
>
  <PageHeader
    eyebrow="How it works"
    title="Durable semantics above replaceable providers."
    lede="Agent OS owns the entities, actions, history, authority and delivery semantics that applications currently fragment. Micro-apps assemble the needed interface; Agent Mesh carries the same objects across direct, off-grid and delayed paths."
  />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader
        eyebrow="The premise"
        title="Apps become views. The work becomes the system."
        lede="Today identity, actions, interfaces and history are fragmented by application. Agent OS keeps one object graph and lets many views, agents, micro-apps and replaceable providers operate on it."
      />
      <div class="mt-10 max-w-4xl">
        <AppLastDiagram />
      </div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader eyebrow="The vision core" title="Six pillars." />
      <div class="mt-12"><PillarGrid /></div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:items-start">
        <SectionHeader
          eyebrow="Architecture"
          title="Seven layers, explicit contracts."
          lede="Kernel policy stays minimal. Drivers, compatibility, graphics, entity services, micro-apps, connectivity policy and agents live in isolated user-space domains behind versioned contracts."
        />
        <LayerStack />
      </div>
    </div>
  </section>

  <GlobalAccount />
  <MicroApps />
  <AgentMeshTeaser />

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader eyebrow="The rules that hold it together" title="Four invariants." />
      <div class="mt-12"><FeatureTiles tiles={rules} /></div>
    </div>
  </section>

  <section class="section border-b border-border">
    <div class="mx-auto max-w-6xl px-6">
      <SectionHeader eyebrow="Go deeper" title="Read the source specs." />
      <div class="mt-10">
        <SpecLinks
          links={[
            { label: 'Storage, entity graph, history & sync', path: 'engineering-bible/docs/architecture/AOS-ARCH-009.md' },
            { label: 'Agent runtime & action safety', path: 'engineering-bible/docs/architecture/AOS-ARCH-010.md' },
            { label: 'Text-to-Micro-App Builder', path: 'engineering-bible/docs/product/PROD-018-text-to-micro-app-builder.md' },
            { label: 'Micro-App Runtime', path: 'engineering-bible/docs/architecture/ARCH-026-micro-app-runtime.md' },
            { label: 'Agent Mesh connectivity', path: 'engineering-bible/docs/architecture/ARCH-024-agent-mesh-connectivity.md' },
            { label: 'Executive briefing', path: 'engineering-bible/docs/AOS-BRIEF.md' },
          ]}
        />
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
