---
import { proofPoints } from '../data/content';
---

<div class="grid gap-px overflow-hidden rounded-xl border border-border bg-border sm:grid-cols-2 lg:grid-cols-4">
  {
    proofPoints.map((p) => (
      <div class="bg-card p-6">
        <div class="font-mono text-3xl font-semibold tracking-tight text-foreground">{p.stat}</div>
        <div class="mt-1 text-sm font-medium text-signal">{p.label}</div>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{p.body}</p>
      </div>
    ))
  }
</div>
