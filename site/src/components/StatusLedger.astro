---
import { statusRows } from '../data/content';

const badge: Record<string, { label: string; cls: string }> = {
  today: { label: 'Today', cls: 'border-emerald-500/40 bg-emerald-500/10 text-emerald-400' },
  decided: { label: 'Decided', cls: 'border-signal/40 bg-signal/10 text-signal' },
  next: { label: 'Next', cls: 'border-amber-500/40 bg-amber-500/10 text-amber-400' },
  planned: { label: 'Planned', cls: 'border-border bg-muted/40 text-muted-foreground' },
  gap: { label: 'Open gap', cls: 'border-red-500/40 bg-red-500/10 text-red-400' },
};
---

<div class="overflow-hidden rounded-xl border border-border">
  {
    statusRows.map((r, i) => {
      const b = badge[r.state];
      return (
        <div class={'flex items-center justify-between gap-4 px-5 py-3.5 ' + (i > 0 ? 'border-t border-border' : '')}>
          <span class="text-sm text-foreground">{r.item}</span>
          <span class={'shrink-0 rounded-md border px-2 py-0.5 font-mono text-[0.68rem] ' + b.cls}>{b.label}</span>
        </div>
      );
    })
  }
</div>
<p class="mt-3 text-xs leading-relaxed text-muted-foreground">
  Honest framing: identity/accounts and end-user developer distribution are genuine open gaps, stated plainly rather than papered over.
</p>
