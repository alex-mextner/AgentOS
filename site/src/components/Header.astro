---
import { navLinks } from '../data/content';
import ThemeToggle from './ThemeToggle.tsx';
import MobileNav from './MobileNav.tsx';
import Logo from './Logo.astro';

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-30 border-b border-border bg-background/90 backdrop-blur-xl">
  <div class="mx-auto flex h-14 max-w-6xl items-center gap-4 px-4 sm:px-6">
    <div class="hidden shrink-0 items-center gap-2.5 md:flex">
      <a href="/" class="flex items-center gap-2.5" aria-label="Agent OS home">
        <Logo class="h-6 w-6" />
        <span class="text-sm font-semibold tracking-tight">Agent OS</span>
      </a>
    </div>

    <nav class="hidden min-w-0 flex-1 items-center justify-center gap-0.5 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden md:flex" aria-label="Primary">
      {
        navLinks.map((link) => {
          const active = current === link.href || (link.href !== '/' && current.startsWith(link.href));
          return (
            <a
              href={link.href}
              aria-current={active ? 'page' : undefined}
              class={
                'shrink-0 rounded-full px-3 py-1.5 text-sm transition-colors ' +
                (active
                  ? 'bg-accent text-foreground'
                  : 'text-muted-foreground hover:bg-accent/60 hover:text-foreground')
              }
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <MobileNav client:load links={navLinks} current={current} />

    <div class="hidden shrink-0 items-center gap-2 md:flex">
      <a
        href="https://github.com/alex-mextner/AgentOS"
        class="text-sm text-muted-foreground transition-colors hover:text-foreground lg:inline-flex"
        rel="noopener"
      >
        GitHub
      </a>
      <ThemeToggle client:load />
    </div>
  </div>
</header>
