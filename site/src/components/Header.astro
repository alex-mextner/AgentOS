---
import { navLinks } from '../data/content';
import ThemeToggle from './ThemeToggle.tsx';
import MobileNav from './MobileNav.tsx';
import Logo from './Logo.astro';

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-30 border-b border-border bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-4 px-6">
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label="Agent OS home">
      <Logo class="h-6 w-6" />
      <span class="text-sm font-semibold tracking-tight">Agent OS</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        navLinks.map((l) => {
          const active = current === l.href || (l.href !== '/' && current.startsWith(l.href));
          return (
            <a
              href={l.href}
              aria-current={active ? 'page' : undefined}
              class={
                'rounded-md px-3 py-1.5 text-sm transition-colors ' +
                (active
                  ? 'text-foreground'
                  : 'text-muted-foreground hover:text-foreground')
              }
            >
              {l.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/alex-mextner/AgentOS"
        class="hidden text-sm text-muted-foreground transition-colors hover:text-foreground sm:inline-flex"
        rel="noopener"
      >
        GitHub
      </a>
      <ThemeToggle client:load />
      <MobileNav client:load links={navLinks} current={current} />
    </div>
  </div>
</header>
