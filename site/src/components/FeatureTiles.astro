---
interface Tile {
  title: string;
  body: string;
  cite?: string;
}
interface Props {
  tiles: Tile[];
  cols?: 2 | 3;
}
import Cite from './Cite.astro';
const { tiles, cols = 2 } = Astro.props;
const grid = cols === 3 ? 'sm:grid-cols-2 lg:grid-cols-3' : 'sm:grid-cols-2';
---

<div class={'grid gap-4 ' + grid}>
  {
    tiles.map((t) => (
      <article class="flex flex-col rounded-xl border border-border bg-card p-6">
        <div class="flex items-start justify-between gap-3">
          <h3 class="text-base font-semibold tracking-tight">{t.title}</h3>
          {t.cite && <Cite id={t.cite} />}
        </div>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{t.body}</p>
      </article>
    ))
  }
</div>
