---
interface Props {
  eyebrow: string;
  title: string;
  lede: string;
}
const { eyebrow, title, lede } = Astro.props;
---

<section class="border-b border-border">
  <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
    <div class="max-w-3xl">
      <div class="eyebrow mb-3 text-signal/90">{eyebrow}</div>
      <h1 class="text-balance text-4xl font-semibold leading-[1.08] tracking-tight md:text-5xl">{title}</h1>
      <p class="mt-5 text-pretty text-lg leading-relaxed text-muted-foreground">{lede}</p>
    </div>
  </div>
</section>
