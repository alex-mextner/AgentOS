---
// Signature element: the app-first → app-last shift, made visual.
// Left: six disconnected app silos. Right: one entity graph with the current object
// at the centre and replaceable views/providers orbiting it. This is the thesis.
const silos = ['Mail', 'Chat', 'Notes', 'Tasks', 'Calendar', 'Files'];
const ring = ['Document', 'Task', 'Person', 'Event', 'Message', 'Agent plan'];
---

<div class="grid items-stretch gap-4 rounded-xl border border-border bg-card/50 p-4 sm:grid-cols-[1fr_auto_1.15fr] sm:p-6">
  <!-- App-first -->
  <div class="flex flex-col rounded-lg border border-border/70 bg-background/40 p-4">
    <div class="eyebrow mb-3">App-first</div>
    <div class="grid grid-cols-3 gap-2">
      {
        silos.map((s) => (
          <span class="flex h-11 items-center justify-center rounded-md border border-border bg-muted/40 text-xs text-muted-foreground">
            {s}
          </span>
        ))
      }
    </div>
    <p class="mt-3 text-xs leading-relaxed text-muted-foreground">
      Identity, actions and history are fragmented by application.
    </p>
  </div>

  <!-- Arrow -->
  <div class="flex items-center justify-center py-1 sm:py-0">
    <div
      class="flex h-8 w-8 items-center justify-center rounded-full border border-border bg-background text-muted-foreground sm:h-9 sm:w-9"
      aria-hidden="true"
    >
      <svg viewBox="0 0 24 24" class="h-4 w-4 rotate-90 sm:rotate-0" fill="none" stroke="currentColor" stroke-width="1.75">
        <path d="M5 12h14M13 6l6 6-6 6" />
      </svg>
    </div>
    <span class="sr-only">becomes</span>
  </div>

  <!-- App-last -->
  <div class="relative flex flex-col rounded-lg border border-signal/30 bg-signal/[0.04] p-4">
    <div class="eyebrow mb-3 text-signal/90">App-last</div>
    <div class="relative flex flex-1 items-center justify-center py-2">
      <div class="grid w-full grid-cols-3 items-center gap-2">
        {
          ring.slice(0, 3).map((r) => (
            <span class="flex h-9 items-center justify-center rounded-md border border-border bg-background/60 text-[0.7rem] text-muted-foreground">
              {r}
            </span>
          ))
        }
        <div class="col-span-3 flex justify-center py-1.5">
          <span class="flex h-12 items-center justify-center rounded-md border border-signal/50 bg-signal/15 px-5 text-sm font-medium text-foreground">
            Project
          </span>
        </div>
        {
          ring.slice(3).map((r) => (
            <span class="flex h-9 items-center justify-center rounded-md border border-border bg-background/60 text-[0.7rem] text-muted-foreground">
              {r}
            </span>
          ))
        }
      </div>
    </div>
    <p class="mt-3 text-xs leading-relaxed text-muted-foreground">
      One object graph. Many views and replaceable providers.
    </p>
  </div>
</div>
