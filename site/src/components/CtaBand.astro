---
import WaitlistForm from './WaitlistForm.tsx';

interface Props {
  title?: string;
  body?: string;
}
const {
  title = 'Use it first.',
  body = 'For people who create and change things — not the mass market. Join the waitlist to hear when the first builds open up.',
} = Astro.props;
---

<section class="section">
  <div class="mx-auto max-w-6xl px-6">
    <div class="relative overflow-hidden rounded-2xl border border-border bg-card px-6 py-12 sm:px-10 md:py-16">
      <div
        class="pointer-events-none absolute inset-0 opacity-40 [mask-image:radial-gradient(ellipse_at_right,black,transparent_75%)]"
        aria-hidden="true"
        style="background-image:radial-gradient(circle at 85% 30%, hsl(var(--signal)/0.14), transparent 55%);"
      >
      </div>
      <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div class="max-w-xl">
          <h2 class="text-balance text-3xl font-semibold tracking-tight md:text-4xl">{title}</h2>
          <p class="mt-3 text-pretty text-muted-foreground">{body}</p>
        </div>
        <WaitlistForm client:visible />
      </div>
    </div>
  </div>
</section>
