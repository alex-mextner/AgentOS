---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, lede, align = 'left' } = Astro.props;
const wrap = align === 'center' ? 'text-center mx-auto max-w-2xl' : 'max-w-2xl';
---

<div class={wrap}>
  {eyebrow && <div class="eyebrow mb-3">{eyebrow}</div>}
  <h2 class="text-balance text-3xl font-semibold tracking-tight md:text-4xl">{title}</h2>
  {lede && <p class="mt-4 text-pretty text-base leading-relaxed text-muted-foreground md:text-lg">{lede}</p>}
</div>
