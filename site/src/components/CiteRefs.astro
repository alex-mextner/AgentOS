---
// Renders a bracketed citation string ("[14][16]" | "[AOS-ARCH-004][ARCH-022]") as
// interactive register chips: numbered refs open the source reference, doc-ids open the
// in-portal document — both via the RefDialog preview. Unresolvable tokens stay inert.
import { resolveDocId, docHref } from '../lib/bible';

interface Props {
  refs: string;
}
const { refs } = Astro.props;

type Token =
  | { type: 'ref'; n: number }
  | { type: 'doc'; id: string; raw: string }
  | { type: 'text'; raw: string };

function parse(input: string): Token[] {
  const tokens: Token[] = [];
  const re = /\[([^\]]+)\]/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(input)) !== null) {
    const inner = m[1].trim();
    if (/^\d{1,3}$/.test(inner)) {
      tokens.push({ type: 'ref', n: Number(inner) });
      continue;
    }
    const canon = resolveDocId(inner);
    if (canon) tokens.push({ type: 'doc', id: canon, raw: inner });
    else tokens.push({ type: 'text', raw: `[${inner}]` });
  }
  return tokens;
}

const tokens = parse(refs);
---

{
  tokens.map((t) =>
    t.type === 'ref' ? (
      <button type="button" class="cite cite-interactive ml-0.5 align-middle" data-ref={t.n}>
        [{t.n}]
      </button>
    ) : t.type === 'doc' ? (
      <a class="cite cite-interactive ml-0.5 align-middle" href={docHref(t.id)} data-doc-id={t.id} title={`Preview ${t.raw}`}>
        [{t.raw}]
      </a>
    ) : (
      <span class="cite ml-0.5 align-middle">{t.raw}</span>
    )
  )
}
